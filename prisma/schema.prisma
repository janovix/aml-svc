  xmlFileUrl     String?      @map("xml_file_url")
  fileSize       Int?         @map("file_size")
  generatedAt    DateTime?    @map("generated_at")
  submittedAt    DateTime?    @map("submitted_at")
  amendmentCycle Int          @default(0) @map("amendment_cycle")
  createdBy      String?      @map("created_by")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  alerts Alert[]
  events NoticeEvent[]

  @@index([organizationId])
  @@index([organizationId, environment])
  @@index([activityCode])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([reportedMonth])
  @@map("notices")
}

model NoticeEvent {
  id             String   @id
  noticeId       String   @map("notice_id")
  organizationId String   @map("organization_id")
  environment    String   @default("production") @map("environment")
  eventType      String   @map("event_type")
  fromStatus     String?  @map("from_status")
  toStatus       String   @map("to_status")
  cycle          Int      @default(0)
  pdfDocumentId  String?  @map("pdf_document_id")
  xmlFileUrl     String?  @map("xml_file_url")
  fileSize       Int?     @map("file_size")
  notes          String?
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@index([noticeId])
  @@index([organizationId])
  @@index([eventType])
  @@map("notice_events")
}

// ============================================================================
// Report Domain (Analytics)
// ============================================================================

model Report {
  id                    String           @id
  organizationId        String           @map("organization_id")
  environment           String           @default("production") @map("environment")
  name                  String
  template              ReportTemplate   @default(CUSTOM)
  periodType            ReportPeriodType @default(CUSTOM) @map("period_type")
  periodStart           DateTime         @map("period_start")
  periodEnd             DateTime         @map("period_end")
  comparisonPeriodStart DateTime?        @map("comparison_period_start")
  comparisonPeriodEnd   DateTime?        @map("comparison_period_end")
  dataSources           String           @default("[\"ALERTS\"]") @map("data_sources")
  filters               String           @default("{}")
  clientId              String?          @map("client_id")
  charts                String           @default("[]")
  includeSummaryCards   Boolean          @default(true) @map("include_summary_cards")
  includeDetailTables   Boolean          @default(true) @map("include_detail_tables")
  status                ReportStatus     @default(DRAFT)
  pdfFileUrl            String?          @map("pdf_file_url")
  fileSize              Int?             @map("file_size")
  generatedAt           DateTime?        @map("generated_at")
  createdBy             String?          @map("created_by")
  notes                 String?
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  alerts Alert[]
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, environment])
  @@index([template])
  @@index([periodType])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([clientId])
  @@map("reports")
}

// ============================================================================
// Alert System Domain
// ============================================================================

model AlertRule {
  id           String        @id
  name         String
  description  String?
  active       Boolean       @default(true)
  severity     AlertSeverity @default(MEDIUM)
  ruleType     String?       @map("rule_type")
  isManualOnly Boolean       @default(false) @map("is_manual_only")
  activityCode String        @default("VEH") @map("activity_code")
  metadata     String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  alerts  Alert[]
  configs AlertRuleConfig[]

  @@index([active])
  @@index([severity])
  @@index([ruleType])
  @@index([activityCode])
  @@index([isManualOnly])
  @@map("alert_rules")
}

model AlertRuleConfig {
  id          String   @id
  alertRuleId String   @map("alert_rule_id")
  key         String
  value       String
  isHardcoded Boolean  @default(false) @map("is_hardcoded")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)

  @@unique([alertRuleId, key])
  @@index([alertRuleId])
  @@index([key])
  @@index([isHardcoded])
  @@map("alert_rule_config")
}

model Alert {
  id                       String        @id
  organizationId           String        @map("organization_id")
  environment              String        @default("production") @map("environment")
  alertRuleId              String        @map("alert_rule_id")
  clientId                 String        @map("client_id")
  reportId                 String?       @map("report_id")
  noticeId                 String?       @map("notice_id")
  operationId              String?       @map("operation_id")
  activityCode             String        @default("VEH") @map("activity_code")
  status                   AlertStatus   @default(DETECTED)
  severity                 AlertSeverity
  idempotencyKey           String        @unique @map("idempotency_key")
  contextHash              String        @map("context_hash")
  metadata                 String
  isManual                 Boolean       @default(false) @map("is_manual")
  submissionDeadline       DateTime?     @map("submission_deadline")
  fileGeneratedAt          DateTime?     @map("file_generated_at")
  submittedAt              DateTime?     @map("submitted_at")
  satAcknowledgmentReceipt String?       @map("sat_acknowledgment_receipt")
  satFolioNumber           String?       @map("sat_folio_number")
  isOverdue                Boolean       @default(false) @map("is_overdue")
  notes                    String?
  reviewedAt               DateTime?     @map("reviewed_at")
  reviewedBy               String?       @map("reviewed_by")
  cancelledAt              DateTime?     @map("cancelled_at")
  cancelledBy              String?       @map("cancelled_by")
  cancellationReason       String?       @map("cancellation_reason")
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")

  alertRule AlertRule  @relation(fields: [alertRuleId], references: [id], onDelete: Restrict)
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  report    Report?    @relation(fields: [reportId], references: [id], onDelete: SetNull)
  notice    Notice?    @relation(fields: [noticeId], references: [id], onDelete: SetNull)
  operation Operation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, environment])
  @@index([alertRuleId])
  @@index([clientId])
  @@index([reportId])
  @@index([noticeId])
  @@index([operationId])
  @@index([activityCode])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@index([idempotencyKey])
  @@index([submissionDeadline])
  @@index([isOverdue])
  @@index([submittedAt])
  @@index([isManual])
  @@map("alerts")
}

// ============================================================================
// Import Domain (Bulk Data Import)
// ============================================================================

model Import {
  id             String           @id
  organizationId String           @map("organization_id")
  environment    String           @default("production") @map("environment")
  entityType     ImportEntityType @map("entity_type")
  activityCode   String?          @map("activity_code")
  fileName       String           @map("file_name")
  fileUrl        String           @map("file_url")
  fileSize       Int              @map("file_size")
  status         ImportStatus     @default(PENDING)
  totalRows      Int              @default(0) @map("total_rows")
  processedRows  Int              @default(0) @map("processed_rows")
  successCount   Int              @default(0) @map("success_count")
  warningCount   Int              @default(0) @map("warning_count")
  errorCount     Int              @default(0) @map("error_count")
  skippedCount   Int              @default(0) @map("skipped_count")
  errorMessage   String?          @map("error_message")
  columnMapping  Json?            @map("column_mapping")
  createdBy      String           @map("created_by")
  startedAt      DateTime?        @map("started_at")
  completedAt    DateTime?        @map("completed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  rowResults ImportRowResult[]

  @@index([organizationId])
  @@index([organizationId, environment])
  @@index([status])
  @@index([entityType])
  @@index([createdAt])
  @@index([createdBy])
  @@map("imports")
}

model ImportRowResult {
  id        String          @id
  importId  String          @map("import_id")
  rowNumber Int             @map("row_number")
  status    ImportRowStatus @default(PENDING)
  rawData   String          @map("raw_data")
  entityId  String?         @map("entity_id")
  message   String?
  errors    String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  import Import @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([status])
  @@index([rowNumber])
  @@map("import_row_results")
}

// ============================================================================
// Risk-Based Approach Domain (Art. 18-VII through XI LFPIORPI Reform 2025)
// ============================================================================

// Reference catalog: geographic risk zones derived from ENR 2023
model GeographicRiskZone {
  id        String   @id
  stateCode String   @map("state_code")
  stateName String   @map("state_name")
  riskLevel String   @map("risk_level")
  riskScore Float    @map("risk_score")
  factors   String?
  source    String   @default("ENR_2023")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([stateCode])
  @@map("geographic_risk_zones")
}

// Reference catalog: activity risk profiles from ENR 2023 sectoral ratings
model ActivityRiskProfile {
  id              String   @id
  activityKey     String   @unique @map("activity_key")
  activityName    String   @map("activity_name")
  riskLevel       String   @map("risk_level")
  riskScore       Float    @map("risk_score")
  liquidityFactor Float    @map("liquidity_factor")
  anonymityFactor Float    @map("anonymity_factor")
  valueTransfer   Float    @map("value_transfer_factor")
  cashIntensity   Float    @map("cash_intensity_factor")
  source          String   @default("ENR_2023")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("activity_risk_profiles")
}

// Reference catalog: jurisdiction risk list (GAFI/GAFILAT high-risk countries)
model JurisdictionRisk {
  id              String   @id
  countryCode     String   @unique @map("country_code")
  countryName     String   @map("country_name")
  riskLevel       String   @map("risk_level")
  riskScore       Float    @map("risk_score")
  preferentialTax Boolean  @default(false) @map("preferential_tax")
  gafiDeficient   Boolean  @default(false) @map("gafi_deficient")
  highCorruption  Boolean  @default(false) @map("high_corruption")
  source          String   @default("GAFI_2023")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("jurisdiction_risks")
}

// Organization Risk Assessment (Art. 18-VII -- entity side)
model OrgRiskAssessment {
  id                  String    @id
  organizationId      String    @map("organization_id")
  environment         String    @default("production") @map("environment")
  methodologyId       String?   @map("methodology_id")
  status              String    @map("status")
  inherentRiskScore   Float?    @map("inherent_risk_score")
  residualRiskScore   Float?    @map("residual_risk_score")
  riskLevel           String?   @map("risk_level")
  requiredAuditType   String?   @map("required_audit_type")
  fpRiskLevel         String?   @map("fp_risk_level")
  fpRiskJustification String?   @map("fp_risk_justification")
  periodStartDate     DateTime  @map("period_start_date")
  periodEndDate       DateTime  @map("period_end_date")
  assessedBy          String    @map("assessed_by")
  nextReviewDeadline  DateTime? @map("next_review_deadline")
  version             Int       @default(1)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @map("updated_at")

  elements  OrgRiskElement[]
  mitigants OrgMitigant[]

  @@index([organizationId])
  @@index([status])
  @@map("org_risk_assessments")
}

// Element-level breakdown (4 risk elements per ENR/GAFI)
model OrgRiskElement {
  id              String @id
  assessmentId    String @map("assessment_id")
  elementType     String @map("element_type")
  weight          Float
  riskScore       Float  @map("risk_score")
  riskLevel       String @map("risk_level")
  factorBreakdown String @map("factor_breakdown")
  justification   String?

  assessment OrgRiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("org_risk_elements")
}

// Mitigant tracking for organization EBR
model OrgMitigant {
  id                 String  @id
  assessmentId       String  @map("assessment_id")
  mitigantKey        String  @map("mitigant_key")
  mitigantName       String  @map("mitigant_name")
  exists             Boolean @default(true)
  effectivenessScore Float   @map("effectiveness_score")
  riskEffect         Float   @map("risk_effect")
  justification      String?

  assessment OrgRiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("org_mitigants")
}

// Client Risk Classification (Art. 18-VII -- client side, per RCG Art. 34)
model ClientRiskAssessment {
  id                String   @id
  clientId          String   @map("client_id")
  organizationId    String   @map("organization_id")
  environment       String   @default("production") @map("environment")
  methodologyId     String?  @map("methodology_id")
  inherentRiskScore Float    @map("inherent_risk_score")
  residualRiskScore Float    @map("residual_risk_score")
  riskLevel         String   @map("risk_level")
  dueDiligenceLevel String   @map("due_diligence_level")
  clientFactors     String   @map("client_factors")
  geographicFactors String   @map("geographic_factors")
  activityFactors   String   @map("activity_factors")
  transactionFactors String  @map("transaction_factors")
  mitigantFactors   String   @map("mitigant_factors")
  assessedAt        DateTime @map("assessed_at")
  nextReviewAt      DateTime @map("next_review_at")
  assessedBy        String   @map("assessed_by")
  triggerReason     String?  @map("trigger_reason")
  version           Int      @default(1)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([organizationId])
  @@index([riskLevel])
  @@index([methodologyId])
  @@map("client_risk_assessments")
}

// ============================================================================
// Risk Methodology Configuration (Dynamic EBR -- FATF R.1 / Art. 18-VII)
// ============================================================================

model RiskMethodology {
  id             String  @id
  scope          String  @map("scope")
  activityKey    String? @map("activity_key")
  organizationId String? @map("organization_id")
  environment    String  @default("production") @map("environment")
  name           String
  description    String?
  version        Int     @default(1)
  status         String  @default("ACTIVE") @map("status")
  scoringFormula String  @default("weighted_sum") @map("scoring_formula")
  scaleMax       Float   @default(9.0) @map("scale_max")
  createdBy      String  @map("created_by")
  approvedBy     String? @map("approved_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  categories RiskCategory[]
  thresholds RiskThreshold[]
  mitigants  RiskMitigantDef[]
  auditLogs  MethodologyAuditLog[]

  @@unique([scope, activityKey, organizationId, status])
  @@index([scope, status])
  @@index([activityKey])
  @@index([organizationId])
  @@map("risk_methodologies")
}

model RiskCategory {
  id            String @id
  methodologyId String @map("methodology_id")
  name          String
  displayName   String @map("display_name")
  weight        Float
  displayOrder  Int    @map("display_order")

  methodology RiskMethodology @relation(fields: [methodologyId], references: [id], onDelete: Cascade)
  factors     RiskFactor[]

  @@index([methodologyId])
  @@map("risk_categories")
}

model RiskFactor {
  id           String  @id
  categoryId   String  @map("category_id")
  name         String
  displayName  String  @map("display_name")
  weight       Float
  factorType   String  @map("factor_type")
  dataSource   String  @map("data_source")
  displayOrder Int     @map("display_order")
  description  String?

  category  RiskCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  scoreMaps RiskFactorScoreMap[]

  @@index([categoryId])
  @@map("risk_factors")
}

model RiskFactorScoreMap {
  id             String  @id
  factorId       String  @map("factor_id")
  conditionType  String  @map("condition_type")
  conditionValue String  @map("condition_value")
  score          Float
  label          String?
  displayOrder   Int     @default(0) @map("display_order")

  factor RiskFactor @relation(fields: [factorId], references: [id], onDelete: Cascade)

  @@index([factorId])
  @@map("risk_factor_score_maps")
}

model RiskThreshold {
  id            String @id
  methodologyId String @map("methodology_id")
  riskLevel     String @map("risk_level")
  minScore      Float  @map("min_score")
  maxScore      Float  @map("max_score")
  ddLevel       String @map("dd_level")
  reviewMonths  Int    @map("review_months")
  displayOrder  Int    @map("display_order")

  methodology RiskMethodology @relation(fields: [methodologyId], references: [id], onDelete: Cascade)

  @@index([methodologyId])
  @@map("risk_thresholds")
}

model RiskMitigantDef {
  id            String @id
  methodologyId String @map("methodology_id")
  mitigantKey   String @map("mitigant_key")
  displayName   String @map("display_name")
  maxEffect     Float  @map("max_effect")
  weight        Float
  dataSource    String @map("data_source")
  displayOrder  Int    @map("display_order")

  methodology RiskMethodology @relation(fields: [methodologyId], references: [id], onDelete: Cascade)

  @@index([methodologyId])
  @@map("risk_mitigant_defs")
}

model MethodologyAuditLog {
  id            String   @id
  methodologyId String   @map("methodology_id")
  changeType    String   @map("change_type")
  previousValue String?  @map("previous_value")
  newValue      String?  @map("new_value")
  changedBy     String   @map("changed_by")
  justification String?
  createdAt     DateTime @default(now()) @map("created_at")

  methodology RiskMethodology @relation(fields: [methodologyId], references: [id], onDelete: Cascade)

  @@index([methodologyId])
  @@map("methodology_audit_logs")
}

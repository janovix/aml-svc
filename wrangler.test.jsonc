{
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_als"],
	"main": "src/index.ts",
	"name": "aml-svc-test",
	"upload_source_maps": true,
	"workers_dev": true,
	"version_metadata": {
		"binding": "CF_VERSION_METADATA",
	},
	"observability": {
		"enabled": true,
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "aml-test",
			"database_id": "test-database-id",
		},
	],
	"kv_namespaces": [
		{
			"binding": "CACHE",
			"id": "test-cache-id",
		},
	],
	"r2_buckets": [
		{
			"binding": "R2_BUCKET",
			"bucket_name": "aml-test-bucket",
		},
	],
	"vars": {
		"ENVIRONMENT": "test",
		"AUTH_JWKS_CACHE_TTL": "3600",
		"TRUSTED_ORIGINS": "*.test.janovix.com,http://localhost:*",
		"AML_FRONTEND_URL": "https://aml.test.local",
		"E2E_API_KEY": "test-e2e-api-key",
	},
}

// Prisma schema for AML Core domain
// Learn more about it in the docs: https://pris.ly/d/prisma-schema
// NOTE: All column names use snake_case via @map directives for consistency
// Supports all 20 SAT vulnerable activities with activity-specific extension models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum PersonType {
  PHYSICAL
  MORAL
  TRUST
}

enum DocumentType {
  // ID Documents
  PASSPORT
  NATIONAL_ID // INE
  DRIVERS_LICENSE
  CEDULA_PROFESIONAL
  CARTILLA_MILITAR
  // Tax Documents
  TAX_ID // RFC / Constancia de Situación Fiscal
  // Address Proof
  PROOF_OF_ADDRESS
  UTILITY_BILL
  BANK_STATEMENT
  // Corporate Documents
  ACTA_CONSTITUTIVA
  PODER_NOTARIAL
  TRUST_AGREEMENT
  CORPORATE_BYLAWS
  // Other
  OTHER
}

enum KYCStatus {
  INCOMPLETE
  PENDING_VERIFICATION
  COMPLETE
  EXPIRED
}

enum PEPStatus {
  PENDING
  CONFIRMED
  NOT_PEP
  ERROR
}

enum UBORelationshipType {
  SHAREHOLDER
  DIRECTOR
  LEGAL_REP
  TRUSTEE
  SETTLOR
  BENEFICIARY
  CONTROLLER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum AddressType {
  RESIDENTIAL
  BUSINESS
  MAILING
  OTHER
}

enum UploadLinkStatus {
  ACTIVE
  EXPIRED
  COMPLETED
}

enum VehicleType {
  LAND
  MARINE
  AIR
}

enum WatchlistStatus {
  PENDING
  QUEUED
  CHECKING
  COMPLETED
  ERROR
  NOT_AVAILABLE
}

enum AlertStatus {
  DETECTED
  FILE_GENERATED
  SUBMITTED
  OVERDUE
  CANCELLED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NoticeStatus {
  DRAFT
  GENERATED
  SUBMITTED
  ACKNOWLEDGED
}

enum ReportPeriodType {
  MONTHLY
  QUARTERLY
  ANNUAL
  CUSTOM
}

enum ReportTemplate {
  EXECUTIVE_SUMMARY
  COMPLIANCE_STATUS
  TRANSACTION_ANALYSIS
  CLIENT_RISK_PROFILE
  ALERT_BREAKDOWN
  PERIOD_COMPARISON
  CUSTOM
}

enum ReportStatus {
  DRAFT
  GENERATED
}

enum ImportStatus {
  PENDING
  VALIDATING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportEntityType {
  CLIENT
  OPERATION
}

enum ImportRowStatus {
  PENDING
  SUCCESS
  WARNING
  ERROR
  SKIPPED
}

// ============================================================================
// Client Domain
// ============================================================================

model Client {
  id                   String     @id
  rfc                  String
  organizationId       String     @map("organization_id")
  personType           PersonType @map("person_type")
  firstName            String?    @map("first_name")
  lastName             String?    @map("last_name")
  secondLastName       String?    @map("second_last_name")
  birthDate            DateTime?  @map("birth_date")
  curp                 String?
  businessName         String?    @map("business_name")
  incorporationDate    DateTime?  @map("incorporation_date")
  nationality          String?
  email                String
  phone                String
  country              String
  stateCode            String     @map("state_code")
  city                 String
  municipality         String
  neighborhood         String
  street               String
  externalNumber       String     @map("external_number")
  internalNumber       String?    @map("internal_number")
  postalCode           String     @map("postal_code")
  reference            String?
  notes                String?
  countryCode          String?    @map("country_code")
  economicActivityCode String?    @map("economic_activity_code")
  // Enhanced KYC fields
  gender               String?
  occupation           String?
  maritalStatus        String?    @map("marital_status")
  sourceOfFunds        String?    @map("source_of_funds")
  sourceOfWealth       String?    @map("source_of_wealth")
  // KYC status tracking
  kycStatus            KYCStatus  @default(INCOMPLETE) @map("kyc_status")
  kycCompletedAt       DateTime?  @map("kyc_completed_at")
  // Data completeness tracking
  completenessStatus   String     @default("INCOMPLETE") @map("completeness_status") // COMPLETE, INCOMPLETE, MINIMUM
  missingFields        String?    @map("missing_fields") // JSON array of missing field names
  // PEP status tracking
  isPEP                Boolean    @default(false) @map("is_pep")
  pepStatus            PEPStatus  @default(PENDING) @map("pep_status")
  pepDetails           String?    @map("pep_details")
  pepMatchConfidence   String?    @map("pep_match_confidence")
  pepCheckedAt         DateTime?  @map("pep_checked_at")
  pepCheckSource       String?    @map("pep_check_source")
  // Timestamps
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  documents   ClientDocument[]
  addresses   ClientAddress[]
  operations  Operation[]
  alerts      Alert[]
  reports     Report[]
  ubos        UltimateBeneficialOwner[]
  uploadLinks UploadLink[]

  @@index([organizationId])
  @@index([rfc])
  @@index([personType])
  @@index([deletedAt])
  @@index([countryCode])
  @@index([economicActivityCode])
  @@index([kycStatus])
  @@index([pepStatus])
  @@index([pepCheckedAt])
  @@map("clients")
}

model UploadLink {
  id                String           @id
  organizationId    String           @map("organization_id")
  clientId          String?          @map("client_id")
  createdBy         String           @map("created_by")
  docSvcLinkId      String           @map("doc_svc_link_id")
  expiresAt         DateTime         @map("expires_at")
  status            UploadLinkStatus @default(ACTIVE)
  requiredDocuments String?          @map("required_documents")
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  client    Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  documents ClientDocument[]

  @@index([organizationId])
  @@index([clientId])
  @@index([docSvcLinkId])
  @@index([status])
  @@index([expiresAt])
  @@map("upload_links")
}

model ClientDocument {
  id               String         @id
  clientId         String         @map("client_id")
  documentType     DocumentType   @map("document_type")
  documentNumber   String         @map("document_number")
  issuingCountry   String?        @map("issuing_country")
  issueDate        DateTime?      @map("issue_date")
  expiryDate       DateTime?      @map("expiry_date")
  status           DocumentStatus @default(PENDING)
  fileUrl          String?        @map("file_url")
  metadata         String?
  docSvcDocumentId String?        @map("doc_svc_document_id")
  uploadLinkId     String?        @map("upload_link_id")
  verifiedAt       DateTime?      @map("verified_at")
  verifiedBy       String?        @map("verified_by")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  client           Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadLink       UploadLink?               @relation(fields: [uploadLinkId], references: [id], onDelete: SetNull)
  uboIdDocuments   UltimateBeneficialOwner[] @relation("UBOIdDocument")
  uboAddressProofs UltimateBeneficialOwner[] @relation("UBOAddressProof")

  @@index([clientId])
  @@index([documentType])
  @@index([status])
  @@index([expiryDate])
  @@index([docSvcDocumentId])
  @@index([uploadLinkId])
  @@map("client_documents")
}

model ClientAddress {
  id          String      @id
  clientId    String      @map("client_id")
  addressType AddressType @default(RESIDENTIAL) @map("address_type")
  street1     String
  street2     String?
  city        String
  state       String?
  postalCode  String?     @map("postal_code")
  country     String
  isPrimary   Boolean     @default(false) @map("is_primary")
  verifiedAt  DateTime?   @map("verified_at")
  reference   String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([addressType])
  @@index([country])
  @@map("client_addresses")
}

model UltimateBeneficialOwner {
  id                  String              @id
  clientId            String              @map("client_id")
  firstName           String              @map("first_name")
  lastName            String              @map("last_name")
  secondLastName      String?             @map("second_last_name")
  birthDate           DateTime?           @map("birth_date")
  nationality         String?
  curp                String?
  rfc                 String?
  ownershipPercentage Decimal?            @map("ownership_percentage")
  relationshipType    UBORelationshipType @map("relationship_type")
  position            String?
  email               String?
  phone               String?
  country             String?
  stateCode           String?             @map("state_code")
  city                String?
  street              String?
  postalCode          String?             @map("postal_code")
  idDocumentId        String?             @map("id_document_id")
  addressProofId      String?             @map("address_proof_id")
  isPEP               Boolean             @default(false) @map("is_pep")
  pepStatus           PEPStatus           @default(PENDING) @map("pep_status")
  pepDetails          String?             @map("pep_details")
  pepMatchConfidence  String?             @map("pep_match_confidence")
  pepCheckedAt        DateTime?           @map("pep_checked_at")
  verifiedAt          DateTime?           @map("verified_at")
  verifiedBy          String?             @map("verified_by")
  notes               String?
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  idDocument   ClientDocument? @relation("UBOIdDocument", fields: [idDocumentId], references: [id], onDelete: SetNull)
  addressProof ClientDocument? @relation("UBOAddressProof", fields: [addressProofId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([relationshipType])
  @@index([pepStatus])
  @@index([pepCheckedAt])
  @@map("ultimate_beneficial_owners")
}

// ============================================================================
// Catalog Domain
// ============================================================================

model Catalog {
  id            String        @id
  key           String        @unique
  name          String
  active        Boolean       @default(true)
  allowNewItems Boolean       @default(false) @map("allow_new_items")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  items CatalogItem[]

  @@index([active])
  @@map("catalogs")
}

model CatalogItem {
  id             String   @id
  catalogId      String   @map("catalog_id")
  name           String
  normalizedName String   @map("normalized_name")
  active         Boolean  @default(true)
  metadata       String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@index([normalizedName])
  @@index([active])
  @@map("catalog_items")
}

// ============================================================================
// Invoice Domain (CFDI v4.0)
// ============================================================================

model Invoice {
  id                    String    @id
  organizationId        String    @map("organization_id")
  // CFDI Core
  uuid                  String?   @unique
  version               String    @default("4.0")
  series                String?
  folio                 String?
  // Issuer (Emisor)
  issuerRfc             String    @map("issuer_rfc")
  issuerName            String    @map("issuer_name")
  issuerTaxRegimeCode   String    @map("issuer_tax_regime_code")
  // Receiver (Receptor)
  receiverRfc           String    @map("receiver_rfc")
  receiverName          String    @map("receiver_name")
  receiverUsageCode     String?   @map("receiver_usage_code")
  receiverTaxRegimeCode String?   @map("receiver_tax_regime_code")
  receiverPostalCode    String?   @map("receiver_postal_code")
  // Financial
  subtotal              Decimal
  discount              Decimal?  @default(0)
  total                 Decimal
  currencyCode          String    @default("MXN") @map("currency_code")
  exchangeRate          Decimal?  @default(1) @map("exchange_rate")
  // Payment
  paymentFormCode       String?   @map("payment_form_code")
  paymentMethodCode     String?   @map("payment_method_code")
  // Type and dates
  voucherTypeCode       String    @default("I") @map("voucher_type_code")
  issueDate             DateTime  @map("issue_date")
  certificationDate     DateTime? @map("certification_date")
  // Export
  exportCode            String?   @default("01") @map("export_code")
  // TFD
  tfdUuid               String?   @map("tfd_uuid")
  tfdSatCertificate     String?   @map("tfd_sat_certificate")
  tfdSignature          String?   @map("tfd_signature")
  tfdStampDate          DateTime? @map("tfd_stamp_date")
  // XML
  xmlContent            String?   @map("xml_content")
  // Metadata
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  items      InvoiceItem[]
  operations Operation[]

  @@index([organizationId])
  @@index([uuid])
  @@index([issuerRfc])
  @@index([receiverRfc])
  @@index([issueDate])
  @@index([voucherTypeCode])
  @@index([deletedAt])
  @@map("invoices")
}

model InvoiceItem {
  id                   String   @id
  invoiceId            String   @map("invoice_id")
  productServiceCode   String   @map("product_service_code")
  productServiceId     String?  @map("product_service_id")
  quantity             Decimal
  unitCode             String   @map("unit_code")
  unitName             String?  @map("unit_name")
  description          String
  unitPrice            Decimal  @map("unit_price")
  amount               Decimal
  discount             Decimal? @default(0)
  taxObjectCode        String   @default("02") @map("tax_object_code")
  transferredTaxAmount Decimal? @default(0) @map("transferred_tax_amount")
  withheldTaxAmount    Decimal? @default(0) @map("withheld_tax_amount")
  metadata             String?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([productServiceCode])
  @@map("invoice_items")
}

// ============================================================================
// Operation Domain (Core AML Entity)
// ============================================================================

model Operation {
  id                 String           @id
  organizationId     String           @map("organization_id")
  clientId           String           @map("client_id")
  invoiceId          String?          @map("invoice_id")
  // Activity
  activityCode       String           @map("activity_code")
  operationTypeCode  String?          @map("operation_type_code")
  // Core
  operationDate      DateTime         @map("operation_date")
  branchPostalCode   String           @map("branch_postal_code")
  amount             Decimal
  currencyCode       String           @default("MXN") @map("currency_code")
  exchangeRate       Decimal?         @default(1) @map("exchange_rate")
  amountMxn          Decimal?         @map("amount_mxn")
  // UMA
  umaValue           Decimal?         @map("uma_value")
  umaDailyValue      Decimal?         @map("uma_daily_value")
  // Alert
  alertTypeCode      String           @default("100") @map("alert_type_code")
  alertDescription   String?          @map("alert_description")
  // Watchlist
  watchlistStatus    WatchlistStatus? @default(PENDING) @map("watchlist_status")
  watchlistCheckedAt DateTime?        @map("watchlist_checked_at")
  watchlistResult    String?          @map("watchlist_result")
  watchlistFlags     String?          @map("watchlist_flags")
  // Priority
  priorityCode       String?          @default("2") @map("priority_code")
  // Data origin & completeness
  dataSource         String           @default("MANUAL") @map("data_source") // CFDI, MANUAL, IMPORT, ENRICHED
  completenessStatus String           @default("COMPLETE") @map("completeness_status") // COMPLETE, INCOMPLETE, MINIMUM
  missingFields      String?          @map("missing_fields") // JSON array of missing field names
  // Metadata
  referenceNumber    String?          @map("reference_number")
  notes              String?
  // Timestamps
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payments OperationPayment[]
  alerts   Alert[]

  // Activity extension relations (one-to-one)
  vehicle       OperationVehicle?
  realEstate    OperationRealEstate?
  jewelry       OperationJewelry?
  virtualAsset  OperationVirtualAsset?
  gambling      OperationGambling?
  rental        OperationRental?
  armoring      OperationArmoring?
  donation      OperationDonation?
  loan          OperationLoan?
  official      OperationOfficial?
  notary        OperationNotary?
  professional  OperationProfessional?
  travelerCheck OperationTravelerCheck?
  card          OperationCard?
  prepaid       OperationPrepaid?
  reward        OperationReward?
  valuable      OperationValuable?
  art           OperationArt?
  development   OperationDevelopment?

  @@index([organizationId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([activityCode])
  @@index([operationTypeCode])
  @@index([operationDate])
  @@index([currencyCode])
  @@index([alertTypeCode])
  @@index([watchlistStatus])
  @@index([deletedAt])
  @@map("operations")
}

model OperationPayment {
  id                    String   @id
  operationId           String   @map("operation_id")
  paymentDate           DateTime @map("payment_date")
  paymentFormCode       String   @map("payment_form_code")
  monetaryInstrumentCode String?  @map("monetary_instrument_code")
  currencyCode          String   @default("MXN") @map("currency_code")
  amount                Decimal
  bankName              String?  @map("bank_name")
  accountNumberMasked   String?  @map("account_number_masked")
  checkNumber           String?  @map("check_number")
  reference             String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([operationId])
  @@index([paymentFormCode])
  @@map("operation_payments")
}

// ============================================================================
// Operation Extension Models (Activity-Specific)
// ============================================================================

// VEH: Vehicles
model OperationVehicle {
  id                 String      @id
  operationId        String      @unique @map("operation_id")
  vehicleType        VehicleType @map("vehicle_type")
  brand              String
  model              String
  year               Int
  vin                String?
  repuve             String?
  plates             String?
  serialNumber       String?     @map("serial_number")
  flagCountryCode    String?     @map("flag_country_code")
  registrationNumber String?     @map("registration_number")
  armorLevelCode     String?     @map("armor_level_code")
  engineNumber       String?     @map("engine_number")
  description        String?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([vehicleType])
  @@index([vin])
  @@map("operation_vehicles")
}

// INM: Real Estate
model OperationRealEstate {
  id                   String    @id
  operationId          String    @unique @map("operation_id")
  propertyTypeCode     String    @map("property_type_code")
  street               String?
  externalNumber       String?   @map("external_number")
  internalNumber       String?   @map("internal_number")
  neighborhood         String?
  postalCode           String?   @map("postal_code")
  municipality         String?
  stateCode            String?   @map("state_code")
  countryCode          String?   @default("MEX") @map("country_code")
  registryFolio        String?   @map("registry_folio")
  registryDate         DateTime? @map("registry_date")
  landAreaM2           Decimal?  @map("land_area_m2")
  constructionAreaM2   Decimal?  @map("construction_area_m2")
  clientFigureCode     String?   @map("client_figure_code")
  personFigureCode     String?   @map("person_figure_code")
  description          String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([propertyTypeCode])
  @@index([postalCode])
  @@map("operation_real_estate")
}

// MJR: Jewelry
model OperationJewelry {
  id                 String   @id
  operationId        String   @unique @map("operation_id")
  itemTypeCode       String   @map("item_type_code")
  metalType          String?  @map("metal_type")
  weightGrams        Decimal? @map("weight_grams")
  purity             String?
  jewelryDescription String?  @map("jewelry_description")
  brand              String?
  serialNumber       String?  @map("serial_number")
  tradeUnitCode      String?  @map("trade_unit_code")
  quantity           Decimal? @default(1)
  unitPrice          Decimal? @map("unit_price")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([itemTypeCode])
  @@map("operation_jewelry")
}

// AVI: Virtual Assets
model OperationVirtualAsset {
  id                       String   @id
  operationId              String   @unique @map("operation_id")
  assetTypeCode            String   @map("asset_type_code")
  assetName                String?  @map("asset_name")
  walletAddressOrigin      String?  @map("wallet_address_origin")
  walletAddressDestination String?  @map("wallet_address_destination")
  exchangeName             String?  @map("exchange_name")
  exchangeCountryCode      String?  @map("exchange_country_code")
  assetQuantity            Decimal? @map("asset_quantity")
  assetUnitPrice           Decimal? @map("asset_unit_price")
  blockchainTxHash         String?  @map("blockchain_tx_hash")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([assetTypeCode])
  @@map("operation_virtual_assets")
}

// JYS: Gambling
model OperationGambling {
  id                  String    @id
  operationId         String    @unique @map("operation_id")
  gameTypeCode        String?   @map("game_type_code")
  businessLineCode    String?   @map("business_line_code")
  operationMethodCode String?   @map("operation_method_code")
  prizeAmount         Decimal?  @map("prize_amount")
  betAmount           Decimal?  @map("bet_amount")
  ticketNumber        String?   @map("ticket_number")
  eventName           String?   @map("event_name")
  eventDate           DateTime? @map("event_date")
  propertyTypeCode    String?   @map("property_type_code")
  propertyDescription String?   @map("property_description")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([gameTypeCode])
  @@map("operation_gambling")
}

// ARI: Rentals
model OperationRental {
  id                 String    @id
  operationId        String    @unique @map("operation_id")
  propertyTypeCode   String    @map("property_type_code")
  rentalPeriodMonths Int?      @map("rental_period_months")
  monthlyRent        Decimal?  @map("monthly_rent")
  depositAmount      Decimal?  @map("deposit_amount")
  contractStartDate  DateTime? @map("contract_start_date")
  contractEndDate    DateTime? @map("contract_end_date")
  street             String?
  externalNumber     String?   @map("external_number")
  internalNumber     String?   @map("internal_number")
  neighborhood       String?
  postalCode         String?   @map("postal_code")
  municipality       String?
  stateCode          String?   @map("state_code")
  isPrepaid          Boolean?  @default(false) @map("is_prepaid")
  prepaidMonths      Int?      @map("prepaid_months")
  description        String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([propertyTypeCode])
  @@map("operation_rentals")
}

// BLI: Armoring
model OperationArmoring {
  id                 String   @id
  operationId        String   @unique @map("operation_id")
  itemType           String   @map("item_type")
  itemStatusCode     String?  @map("item_status_code")
  armorLevelCode     String   @map("armor_level_code")
  armoredPartCode    String?  @map("armored_part_code")

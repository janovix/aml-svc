// Prisma schema for AML Core domain
// Learn more about it in the docs: https://pris.ly/d/prisma-schema
// NOTE: All column names use snake_case via @map directives for consistency
// Supports all 20 SAT vulnerable activities with activity-specific extension models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum PersonType {
  PHYSICAL
  MORAL
  TRUST
}

enum DocumentType {
  // ID Documents
  PASSPORT
  NATIONAL_ID // INE
  DRIVERS_LICENSE
  CEDULA_PROFESIONAL
  CARTILLA_MILITAR
  // Tax Documents
  TAX_ID // RFC / Constancia de Situación Fiscal
  // Address Proof
  PROOF_OF_ADDRESS
  UTILITY_BILL
  BANK_STATEMENT
  // Corporate Documents
  ACTA_CONSTITUTIVA
  PODER_NOTARIAL
  TRUST_AGREEMENT
  CORPORATE_BYLAWS
  // Other
  OTHER
}

enum KYCStatus {
  INCOMPLETE
  PENDING_VERIFICATION
  COMPLETE
  EXPIRED
}

enum ShareholderEntityType {
  PERSON
  COMPANY
}

enum BCType {
  SHAREHOLDER
  LEGAL_REP
  TRUSTEE
  SETTLOR
  TRUST_BENEFICIARY
  DIRECTOR
}

enum IdentificationCriteria {
  BENEFIT
  CONTROL
  FALLBACK
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum AddressType {
  RESIDENTIAL
  BUSINESS
  MAILING
  OTHER
}

enum UploadLinkStatus {
  ACTIVE
  EXPIRED
  COMPLETED
}

enum VehicleType {
  LAND
  MARINE
  AIR
}

enum WatchlistStatus {
  PENDING
  QUEUED
  CHECKING
  COMPLETED
  ERROR
  NOT_AVAILABLE
}

enum AlertStatus {
  DETECTED
  FILE_GENERATED
  SUBMITTED
  OVERDUE
  CANCELLED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NoticeStatus {
  DRAFT
  GENERATED
  SUBMITTED
  ACKNOWLEDGED
  REBUKED
}

enum ReportPeriodType {
  MONTHLY
  QUARTERLY
  ANNUAL
  CUSTOM
}

enum ReportTemplate {
  EXECUTIVE_SUMMARY
  COMPLIANCE_STATUS
  OPERATION_ANALYSIS
  CLIENT_RISK_PROFILE
  ALERT_BREAKDOWN
  PERIOD_COMPARISON
  MANUAL_POLITICAS_INTERNAS
  EBR_RESULTS
  CUSTOM
}

enum ReportStatus {
  DRAFT
  GENERATED
}

enum ImportStatus {
  PENDING
  VALIDATING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportEntityType {
  CLIENT
  OPERATION
}

enum ImportRowStatus {
  PENDING
  SUCCESS
  WARNING
  ERROR
  SKIPPED
}

// ============================================================================
// Client Domain
// ============================================================================

model Client {
  id                   String     @id
  rfc                  String
  organizationId       String     @map("organization_id")
  environment          String     @default("production") @map("environment")
  personType           PersonType @map("person_type")
  firstName            String?    @map("first_name")
  lastName             String?    @map("last_name")
  secondLastName       String?    @map("second_last_name")
  birthDate            DateTime?  @map("birth_date")
  curp                 String?
  businessName         String?    @map("business_name")
  incorporationDate    DateTime?  @map("incorporation_date")
  nationality          String?
  email                String
  phone                String
  country              String
  stateCode            String     @map("state_code")
  city                 String
  municipality         String
  neighborhood         String
  street               String
  externalNumber       String     @map("external_number")
  internalNumber       String?    @map("internal_number")
  postalCode           String     @map("postal_code")
  reference            String?
  notes                String?
  countryCode          String?    @map("country_code")
  economicActivityCode String?    @map("economic_activity_code")
  // Enhanced KYC fields
  gender               String?
  occupation           String?
  maritalStatus        String?    @map("marital_status")
  sourceOfFunds        String?    @map("source_of_funds")
  sourceOfWealth       String?    @map("source_of_wealth")
  // KYC status tracking
  kycStatus            KYCStatus  @default(INCOMPLETE) @map("kyc_status")
  kycCompletedAt       DateTime?  @map("kyc_completed_at")
  // Data completeness tracking
  completenessStatus     String    @default("INCOMPLETE") @map("completeness_status") // COMPLETE, INCOMPLETE, MINIMUM
  missingFields          String?   @map("missing_fields") // JSON array of missing field names
  // KYC progress (persisted fields)
  kycCompletionPct       Int       @default(0) @map("kyc_completion_pct")
  documentsComplete      Int       @default(0) @map("documents_complete") // 0 or 1
  documentsCount         Int       @default(0) @map("documents_count")
  documentsRequired      Int       @default(0) @map("documents_required")
  shareholdersCount      Int       @default(0) @map("shareholders_count")
  beneficialControllersCount Int   @default(0) @map("beneficial_controllers_count")
  // Threshold-aware KYC (Art. 17 LFPIORPI)
  identificationRequired  Boolean  @default(true) @map("identification_required")
  identificationTier      String   @default("ALWAYS") @map("identification_tier") // ALWAYS, ABOVE_THRESHOLD, BELOW_THRESHOLD
  identificationThresholdMxn Decimal? @map("identification_threshold_mxn")
  noticeThresholdMxn      Decimal? @map("notice_threshold_mxn")
  // Watchlist screening status
  isPEP                  Boolean   @default(false) @map("is_pep")
  watchlistQueryId       String?   @map("watchlist_query_id")
  ofacSanctioned         Boolean   @default(false) @map("ofac_sanctioned")
  unscSanctioned         Boolean   @default(false) @map("unsc_sanctioned")
  sat69bListed           Boolean   @default(false) @map("sat69b_listed")
  adverseMediaFlagged    Boolean   @default(false) @map("adverse_media_flagged")
  screeningResult        String    @default("pending") @map("screening_result") // "pending", "clear", "flagged"
  screenedAt             DateTime? @map("screened_at")
  // Catalog name resolution
  resolvedNames        String?    @map("resolved_names")
  // Timestamps
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  // Risk-Based Approach (Art. 18-VII LFPIORPI)
  riskLevel              String?   @map("risk_level")
  dueDiligenceLevel      String?   @map("due_diligence_level")
  lastRiskAssessment     DateTime? @map("last_risk_assessment")
  nextRiskReview         DateTime? @map("next_risk_review")

  documents              ClientDocument[]
  addresses              ClientAddress[]
  operations             Operation[]
  alerts                 Alert[]
  reports                Report[]
  shareholders           Shareholder[]
  beneficialControllers  BeneficialController[]
  uploadLinks            UploadLink[]
  riskAssessments        ClientRiskAssessment[]

  @@index([organizationId])
  @@index([organizationId, environment])
  @@index([rfc])
  @@index([personType])
  @@index([deletedAt])
  @@index([countryCode])
  @@index([economicActivityCode])
  @@index([kycStatus])
  @@index([screeningResult])
  @@index([riskLevel])
  @@index([nextRiskReview])
  @@map("clients")
}

model UploadLink {
  id                String           @id
  organizationId    String           @map("organization_id")
  environment       String           @default("production") @map("environment")
  clientId          String?          @map("client_id")
  createdBy         String           @map("created_by")
  docSvcLinkId      String           @map("doc_svc_link_id")
  expiresAt         DateTime         @map("expires_at")
  status            UploadLinkStatus @default(ACTIVE)
  requiredDocuments String?          @map("required_documents")
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  client    Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  documents ClientDocument[]

  @@index([organizationId])
  @@index([clientId])
  @@index([docSvcLinkId])
  @@index([status])
  @@index([expiresAt])
  @@map("upload_links")
}

model ClientDocument {
  id               String         @id
  clientId         String         @map("client_id")
  documentType     DocumentType   @map("document_type")
  documentNumber   String         @map("document_number")
  issuingCountry   String?        @map("issuing_country")
  issueDate        DateTime?      @map("issue_date")
  expiryDate       DateTime?      @map("expiry_date")
  status           DocumentStatus @default(PENDING)
  fileUrl          String?        @map("file_url")
  metadata         String?
  docSvcDocumentId String?        @map("doc_svc_document_id")
  uploadLinkId     String?        @map("upload_link_id")
  verifiedAt       DateTime?      @map("verified_at")
  verifiedBy       String?        @map("verified_by")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  client                     Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadLink                 UploadLink?            @relation(fields: [uploadLinkId], references: [id], onDelete: SetNull)
  shareholderActaConstitutiva Shareholder[]         @relation("ShareholderActaConstitutiva")
  shareholderCedulaFiscal    Shareholder[]          @relation("ShareholderCedulaFiscal")
  shareholderAddressProof    Shareholder[]          @relation("ShareholderAddressProof")
  shareholderPowerOfAttorney Shareholder[]          @relation("ShareholderPowerOfAttorney")
  bcIdCopy                   BeneficialController[] @relation("BCIdCopy")
  bcCurpCopy                 BeneficialController[] @relation("BCCurpCopy")
  bcCedulaFiscal             BeneficialController[] @relation("BCCedulaFiscal")
  bcAddressProof             BeneficialController[] @relation("BCAddressProof")
  bcConstanciaBC             BeneficialController[] @relation("BCConstanciaBC")
  bcPowerOfAttorney          BeneficialController[] @relation("BCPowerOfAttorney")

  @@index([clientId])
  @@index([documentType])
  @@index([status])
  @@index([expiryDate])
  @@index([docSvcDocumentId])
  @@index([uploadLinkId])
  @@map("client_documents")
}

model ClientAddress {
  id          String      @id
  clientId    String      @map("client_id")
  addressType AddressType @default(RESIDENTIAL) @map("address_type")
  street1     String
  street2     String?
  city        String
  state       String?
  postalCode  String?     @map("postal_code")
  country     String
  isPrimary   Boolean     @default(false) @map("is_primary")
  verifiedAt  DateTime?   @map("verified_at")
  reference   String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([addressType])
  @@index([country])
  @@map("client_addresses")
}

model Shareholder {
  id                      String                 @id
  clientId                String                 @map("client_id")
  parentShareholderId     String?                @map("parent_shareholder_id")
  entityType              ShareholderEntityType  @map("entity_type")
  // PERSON fields
  firstName               String?                @map("first_name")
  lastName                String?                @map("last_name")
  secondLastName          String?                @map("second_last_name")
  rfc                     String?
  // COMPANY fields
  businessName            String?                @map("business_name")
  taxId                   String?                @map("tax_id")
  incorporationDate       DateTime?              @map("incorporation_date")
  nationality             String?
  // COMPANY Anexo 4: representative
  representativeName      String?                @map("representative_name")
  representativeCurp      String?                @map("representative_curp")
  representativeRfc       String?                @map("representative_rfc")
  // COMPANY Anexo 4: document references
  actaConstitutivaDocId   String?                @map("acta_constitutiva_doc_id")
  cedulaFiscalDocId       String?                @map("cedula_fiscal_doc_id")
  addressProofDocId       String?                @map("address_proof_doc_id")
  powerOfAttorneyDocId    String?                @map("power_of_attorney_doc_id")
  // Ownership (required)
  ownershipPercentage     Decimal                @map("ownership_percentage")
  // Contact
  email                   String?
  phone                   String?
  // Timestamps
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")

  client               Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parentShareholder    Shareholder?           @relation("ShareholderHierarchy", fields: [parentShareholderId], references: [id], onDelete: Cascade)
  childShareholders    Shareholder[]          @relation("ShareholderHierarchy")
  beneficialControllers BeneficialController[]
  actaConstitutivaDoc  ClientDocument?        @relation("ShareholderActaConstitutiva", fields: [actaConstitutivaDocId], references: [id], onDelete: SetNull)
  cedulaFiscalDoc      ClientDocument?        @relation("ShareholderCedulaFiscal", fields: [cedulaFiscalDocId], references: [id], onDelete: SetNull)
  addressProofDoc      ClientDocument?        @relation("ShareholderAddressProof", fields: [addressProofDocId], references: [id], onDelete: SetNull)
  powerOfAttorneyDoc   ClientDocument?        @relation("ShareholderPowerOfAttorney", fields: [powerOfAttorneyDocId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([parentShareholderId])
  @@index([entityType])
  @@map("shareholders")
}

model BeneficialController {
  id                       String                  @id
  clientId                 String                  @map("client_id")
  shareholderId            String?                 @map("shareholder_id")
  // BC classification
  bcType                   BCType                  @map("bc_type")
  identificationCriteria   IdentificationCriteria  @map("identification_criteria")
  controlMechanism         String?                 @map("control_mechanism")
  isLegalRepresentative    Boolean                 @default(false) @map("is_legal_representative")
  // Anexo 3: personal data (all BCs are natural persons)
  firstName                String                  @map("first_name")
  lastName                 String                  @map("last_name")
  secondLastName           String?                 @map("second_last_name")
  birthDate                DateTime?               @map("birth_date")
  birthCountry             String?                 @map("birth_country")
  nationality              String?
  occupation               String?
  curp                     String?
  rfc                      String?
  // Anexo 3: identification document
  idDocumentType           String?                 @map("id_document_type")
  idDocumentNumber         String?                 @map("id_document_number")
  idDocumentAuthority      String?                 @map("id_document_authority")
  // Anexo 3: document copy references
  idCopyDocId              String?                 @map("id_copy_doc_id")
  curpCopyDocId            String?                 @map("curp_copy_doc_id")
  cedulaFiscalDocId        String?                 @map("cedula_fiscal_doc_id")
  addressProofDocId        String?                 @map("address_proof_doc_id")
  constanciaBcDocId        String?                 @map("constancia_bc_doc_id")
  powerOfAttorneyDocId     String?                 @map("power_of_attorney_doc_id")
  // Contact
  email                    String?
  phone                    String?
  // Address (Anexo 3 requires full address)
  country                  String?
  stateCode                String?                 @map("state_code")
  city                     String?
  street                   String?
  postalCode               String?                 @map("postal_code")
  // Watchlist screening
  isPEP                    Boolean                 @default(false) @map("is_pep")
  watchlistQueryId         String?                 @map("watchlist_query_id")
  ofacSanctioned           Boolean                 @default(false) @map("ofac_sanctioned")
  unscSanctioned           Boolean                 @default(false) @map("unsc_sanctioned")
  sat69bListed             Boolean                 @default(false) @map("sat69b_listed")
  adverseMediaFlagged      Boolean                 @default(false) @map("adverse_media_flagged")
  screeningResult          String                  @default("pending") @map("screening_result")
  screenedAt               DateTime?               @map("screened_at")
  // Verification
  verifiedAt               DateTime?               @map("verified_at")
  verifiedBy               String?                 @map("verified_by")
  notes                    String?
  // Timestamps
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")

  client               Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  shareholder          Shareholder?     @relation(fields: [shareholderId], references: [id], onDelete: SetNull)
  idCopyDoc            ClientDocument?  @relation("BCIdCopy", fields: [idCopyDocId], references: [id], onDelete: SetNull)
  curpCopyDoc          ClientDocument?  @relation("BCCurpCopy", fields: [curpCopyDocId], references: [id], onDelete: SetNull)
  cedulaFiscalDoc      ClientDocument?  @relation("BCCedulaFiscal", fields: [cedulaFiscalDocId], references: [id], onDelete: SetNull)
  addressProofDoc      ClientDocument?  @relation("BCAddressProof", fields: [addressProofDocId], references: [id], onDelete: SetNull)
  constanciaBcDoc      ClientDocument?  @relation("BCConstanciaBC", fields: [constanciaBcDocId], references: [id], onDelete: SetNull)
  powerOfAttorneyDoc   ClientDocument?  @relation("BCPowerOfAttorney", fields: [powerOfAttorneyDocId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([shareholderId])
  @@index([bcType])
  @@index([identificationCriteria])
  @@index([screeningResult])
  @@map("beneficial_controllers")
}

// ============================================================================
// Catalog Domain
// ============================================================================

model Catalog {
  id            String        @id
  key           String        @unique
  name          String
  active        Boolean       @default(true)
  allowNewItems Boolean       @default(false) @map("allow_new_items")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  items CatalogItem[]

  @@index([active])
  @@map("catalogs")
}

model CatalogItem {
  id             String   @id
  catalogId      String   @map("catalog_id")
  name           String
  normalizedName String   @map("normalized_name")
  active         Boolean  @default(true)
  metadata       String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@index([normalizedName])
  @@index([active])
  @@map("catalog_items")
}

// ============================================================================
// Invoice Domain (CFDI v4.0)
// ============================================================================

model Invoice {
  id                    String    @id
  organizationId        String    @map("organization_id")
  environment           String    @default("production") @map("environment")
  // CFDI Core
  uuid                  String?   @unique
  version               String    @default("4.0")
  series                String?
  folio                 String?
  // Issuer (Emisor)
  issuerRfc             String    @map("issuer_rfc")
  issuerName            String    @map("issuer_name")
  issuerTaxRegimeCode   String    @map("issuer_tax_regime_code")
  // Receiver (Receptor)
  receiverRfc           String    @map("receiver_rfc")
  receiverName          String    @map("receiver_name")
  receiverUsageCode     String?   @map("receiver_usage_code")
  receiverTaxRegimeCode String?   @map("receiver_tax_regime_code")
  receiverPostalCode    String?   @map("receiver_postal_code")
  // Financial
  subtotal              Decimal
  discount              Decimal?  @default(0)
  total                 Decimal
  currencyCode          String    @default("MXN") @map("currency_code")
  exchangeRate          Decimal?  @default(1) @map("exchange_rate")
  // Payment
  paymentFormCode       String?   @map("payment_form_code")
  paymentMethodCode     String?   @map("payment_method_code")
  // Type and dates
  voucherTypeCode       String    @default("I") @map("voucher_type_code")
  issueDate             DateTime  @map("issue_date")
  certificationDate     DateTime? @map("certification_date")
  // Export
  exportCode            String?   @default("01") @map("export_code")
  // TFD
  tfdUuid               String?   @map("tfd_uuid")
  tfdSatCertificate     String?   @map("tfd_sat_certificate")
  tfdSignature          String?   @map("tfd_signature")
  tfdStampDate          DateTime? @map("tfd_stamp_date")
  // XML
  xmlContent            String?   @map("xml_content")
  // Metadata
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  items      InvoiceItem[]
  operations Operation[]

  @@index([organizationId])
  @@index([organizationId, environment])
  @@index([uuid])
  @@index([issuerRfc])
  @@index([receiverRfc])
  @@index([issueDate])
  @@index([voucherTypeCode])
  @@index([deletedAt])
  @@map("invoices")
}

model InvoiceItem {
  id                   String   @id
  invoiceId            String   @map("invoice_id")
  productServiceCode   String   @map("product_service_code")
  productServiceId     String?  @map("product_service_id")
  quantity             Decimal
  unitCode             String   @map("unit_code")
  unitName             String?  @map("unit_name")
  description          String
  unitPrice            Decimal  @map("unit_price")
  amount               Decimal
  discount             Decimal? @default(0)
  taxObjectCode        String   @default("02") @map("tax_object_code")
  transferredTaxAmount Decimal? @default(0) @map("transferred_tax_amount")
  withheldTaxAmount    Decimal? @default(0) @map("withheld_tax_amount")
  metadata             String?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([productServiceCode])
  @@map("invoice_items")
}

// ============================================================================
// Operation Domain (Core AML Entity)
// ============================================================================

model Operation {
  id                 String           @id
  organizationId     String           @map("organization_id")
  environment        String           @default("production") @map("environment")
  clientId           String           @map("client_id")
  invoiceId          String?          @map("invoice_id")
  // Activity
  activityCode       String           @map("activity_code")
  operationTypeCode  String?          @map("operation_type_code")
  // Core
  operationDate      DateTime         @map("operation_date")
  branchPostalCode   String           @map("branch_postal_code")
  amount             Decimal
  currencyCode       String           @default("MXN") @map("currency_code")
  exchangeRate       Decimal?         @default(1) @map("exchange_rate")
  amountMxn          Decimal?         @map("amount_mxn")
  // UMA
  umaValue           Decimal?         @map("uma_value")
  umaDailyValue      Decimal?         @map("uma_daily_value")
  // Alert
  alertTypeCode      String           @default("100") @map("alert_type_code")
  alertDescription   String?          @map("alert_description")
  // Watchlist
  watchlistStatus    WatchlistStatus? @default(PENDING) @map("watchlist_status")
  watchlistCheckedAt DateTime?        @map("watchlist_checked_at")
  watchlistResult    String?          @map("watchlist_result")
  watchlistFlags     String?          @map("watchlist_flags")
  // Priority
  priorityCode       String?          @default("2") @map("priority_code")
  // Data origin & completeness
  dataSource         String           @default("MANUAL") @map("data_source") // CFDI, MANUAL, IMPORT, ENRICHED
  completenessStatus String           @default("COMPLETE") @map("completeness_status") // COMPLETE, INCOMPLETE, MINIMUM
  missingFields      String?          @map("missing_fields") // JSON array of missing field names
  // Metadata
  referenceNumber    String?          @map("reference_number")
  notes              String?
  // Import deduplication
  importHash         String?          @map("import_hash")
  // Timestamps
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payments OperationPayment[]
  alerts   Alert[]

  // Activity extension relations (one-to-one)
  vehicle       OperationVehicle?
  realEstate    OperationRealEstate?
  jewelry       OperationJewelry?
  virtualAsset  OperationVirtualAsset?
  gambling      OperationGambling?
  rental        OperationRental?
  armoring      OperationArmoring?
  donation      OperationDonation?
  loan          OperationLoan?
  official      OperationOfficial?
  notary        OperationNotary?
  professional  OperationProfessional?
  travelerCheck OperationTravelerCheck?
  card          OperationCard?
  prepaid       OperationPrepaid?
  reward        OperationReward?
  valuable      OperationValuable?
  art           OperationArt?
  development   OperationDevelopment?

  @@index([organizationId])
  @@index([organizationId, environment])
  @@index([clientId])
  @@index([invoiceId])
  @@index([activityCode])
  @@index([operationTypeCode])
  @@index([operationDate])
  @@index([currencyCode])
  @@index([alertTypeCode])
  @@index([watchlistStatus])
  @@index([deletedAt])
  @@index([organizationId, importHash])
  @@map("operations")
}

model OperationPayment {
  id                    String   @id
  operationId           String   @map("operation_id")
  paymentDate           DateTime @map("payment_date")
